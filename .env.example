# depth-graph-search — API environment variables
# Copy this file to .env and fill in the required values.
# Lines starting with # are comments and are ignored.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# PostgreSQL connection string (type: str, required)
# Must start with postgresql:// or postgresql+psycopg://
DATABASE_URL=postgresql://depth:depth@localhost:5432/depth_graph

# ---------------------------------------------------------------------------
# Provider API Keys — at least one provider must be configured
# ---------------------------------------------------------------------------

# OpenAI API key (type: str, conditionally required)
# Required when LLM_PROVIDER=openai (default).
# Optional when LLM_PROVIDER=openrouter — if provided, OpenAI handles embeddings
# (mixed mode); if absent, OpenRouter handles both LLM and embeddings.
OPENAI_API_KEY=sk-...

# ---------------------------------------------------------------------------
# Optional
# ---------------------------------------------------------------------------

# OpenRouter API key — required only when LLM_PROVIDER=openrouter (type: str, default: None)
# OPENROUTER_API_KEY=

# LLM backend provider (type: "openai"|"openrouter", default: "openai")
# LLM_PROVIDER=openai

# Chat completion model identifier (type: str, default: "gpt-4o")
# LLM_MODEL=gpt-4o

# Embedding model identifier (type: str, default: "text-embedding-3-large")
# EMBEDDING_MODEL=text-embedding-3-large

# Apache AGE graph name (type: str, default: "knowledge_graph")
# GRAPH_NAME=knowledge_graph

# pgvector embedding dimension — must match the chosen embedding model (type: int, default: 3072)
# EMBEDDING_DIMENSIONS=3072

# API server bind address (type: str, default: "0.0.0.0")
# API_HOST=0.0.0.0

# API server bind port (type: int, default: 8000)
# API_PORT=8000

# Log verbosity (type: "debug"|"info"|"warning"|"error", default: "info")
# LOG_LEVEL=info
